# ─────────────────────────────────────────────────────────────────────
#  Forge — Environment Example
#  Copy this file to .env and adjust values as needed.
# ─────────────────────────────────────────────────────────────────────

# SQLite database location (frontend persistence for chat history)
DATABASE_URL=file:/home/z/my-project/db/forge.db

# ─────────────────────────────────────────────────────────────────────
#  Local Python backend (uncomment to point frontend to your local GPU)
# ─────────────────────────────────────────────────────────────────────
# When running the Python backend on your machine (Ollama + CrewAI + ChromaDB),
# edit src/lib/store.ts to use this URL instead of the preview runtime.
#
# NEXT_PUBLIC_AGENT_RUNTIME_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────
#  Ollama (used by python-backend)
# ─────────────────────────────────────────────────────────────────────
# These are read by python-backend/config.py — set them in your shell:
#   export OLLAMA_HOST=http://localhost:11434
#   export FORGE_MODEL=llama3.1:8b
