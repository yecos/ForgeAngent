// Forge — Multi-Agent Local AI System
// Prisma schema: chat history, agents, memory, skills, documents, runs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id          String    @id @default(cuid())
  title       String    @default("New conversation")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  agentRuns   AgentRun[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' | 'assistant' | 'system' | 'tool'
  content        String
  agentName      String?
  toolName       String?
  toolArgs       String?      // JSON
  toolResult     String?      // JSON
  tokensIn       Int          @default(0)
  tokensOut      Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model AgentRun {
  id             String       @id @default(cuid())
  conversationId String
  status         String       @default("pending") // pending | running | completed | failed
  plan           String?      // JSON plan
  result         String?
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?
  steps          AgentStep[]
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model AgentStep {
  id        String   @id @default(cuid())
  runId     String
  agentName String   // orchestrator | coder | researcher | doc_analyst | reviewer
  action    String   // think | tool_call | tool_result | respond
  content   String
  status    String   @default("pending") // pending | running | done | error
  startedAt DateTime @default(now())
  endedAt   DateTime?
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model Document {
  id        String   @id @default(cuid())
  filename  String
  mimetype  String
  size      Int
  chunks    Int      @default(0)
  content   String   // extracted text (for RAG, demo: stored as text)
  summary   String?
  createdAt DateTime @default(now())
}

model Memory {
  id        String   @id @default(cuid())
  kind      String   // fact | preference | skill_reference | event
  content   String
  source    String   @default("user") // user | agent | system
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  trigger     String   // when to use
  steps       String   // JSON array of steps
  uses        Int      @default(0)
  successRate Float    @default(1.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id    String @id
  value String
}
